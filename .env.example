# PostgreSQL connection (required for persistent BioSync storage)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/biosync?schema=public"

# Optional: Vercel Blob token for production-grade PDF storage
# If omitted, files are stored in /public/uploads for local development.
BLOB_READ_WRITE_TOKEN=""

# Frontend API base URL (same-origin by default)
# Use "/api" for local development to avoid port mismatch issues.
NEXT_PUBLIC_API_BASE_URL="/api"
